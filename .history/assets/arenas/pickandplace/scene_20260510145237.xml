<mujoco model="pickandplace">
    <include file="../../robots/ffw_sg2/ffw_sg2.xml"/>
    <!-- <include file="../../robots/stanford_tidybot/tidybot.xml"/> -->

    <!-- 设置一些编译器属性，如模型中所有角度值都使用弧度制 -->
    <compiler angle="radian" />

    <option timestep="0.002" />

    <visual>
        <global realtime="1" />
        <quality shadowsize="16384" numslices="28" offsamples="4" />
        <!-- <headlight diffuse="1 1 1" specular="0.5 0.5 0.5" active="1" /> -->
        <rgba fog="0 1 0 1" haze="1 1 1 1" />
    </visual>

    <default>
        <default class="visual_collision">
            <geom contype="0" conaffinity="0" density="0" group="2"/>
        </default>
        <default class="no_visual_collision">
            <geom group="3" />
        </default>
    </default>

    <asset>
        <!-- 天空盒纹理 -->
        <texture type="skybox" file="../../textures/desert.png" gridsize="3 4" gridlayout=".U..LFRB.D.." />
        <!-- 地板纹理 -->
        <texture name="floor_texture" type="2d" builtin="checker" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" width="512" height="512" />
        <!-- 白色纹理，纯白色 2D 平面纹理，128×128 像素，纯白（rgb1="1 1 1"） -->
        <texture name="white_texture" type="2d" builtin="flat" height="128" rgb1="1 1 1" width="128"/>
        <!-- 实验桌纹理 -->
        <texture name="table_texture" type="2d" file="../../textures/light_wood_v2.png" rgb1="0.8 0.8 0.8" rgb2="0.9 0.9 0.9" width="512" height="512"/>

        <!-- 地板材质 -->
        <material name="floor_material" reflectance="0.3" texture="floor_texture" texrepeat="1 1" texuniform="true" />
        <!-- 桌面材质，使用上面的白色纹理，反光率为0.2，表示轻微反光，不刺眼 -->
        <material name="table_material" texture="table_texture" reflectance="0.2"/>
        <!-- 后面墙壁材质，灰色（RGB 值 0.7 0.7 0.7，透明度 1） -->
        <material name="back_wall_material" texture="white_texture"/>

        <!-- 容器材质：蓝色木纹 -->
        <texture name="container_texture" type="2d" file="../../textures/white-plaster.png"/>
        <material name="container_material" texture="container_texture" reflectance="0.2"/>

        <!-- 定义实验物体 1：can -->
        <mesh name="can_mesh" file="../../objects/meshes/can.msh"/>
        <texture name="can_texture" type="2d" file="../../textures/soda.png"/>
        <material name="can_mat" texture="can_texture" reflectance="0.7" texrepeat="5 5" texuniform="true"/>
    </asset>

    <!-- 定义所有模拟器组件 -->
    <worldbody>
        <!-- 添加灯光 -->
        <light pos="0 0 3" dir="0 0 -1" directional="true"/>
        <!-- 添加地板 大小 0 × 0（仅前两个值有效，平面类型第三个值被忽略；若前两个值为 0，则表示平面无限大）-->
        <geom name="floor" type="plane" pos="0 0 0" size="0 0 .2" material="floor_material"/>

        <!-- 后面的墙 -->
        <geom name="back_wall_obj" type="box" pos="0 4.0 2.0" size="5.0 1.0 2.0" material="back_wall_material"/>

        <!-- NOTE 主实验桌 -->
        <body name="lab_table_body" pos="0 2.0 0.3">
            <geom name="lab_table_body" type="box" size="4.0 1.0 0.3" material="table_material"/>
        </body>

        <!-- NOTE 固定视角，用于全局观察 -->
        <camera name="view_fixed" pos="3 4 2" quat="0.5 0.5 0.5 0.5"/>

        <!-- NOTE 添加 can -->
        <body name="can" pos="-3.0 1.2 0.83">
            <joint type="free" />
            <!-- friction="0.95 0.3 0.1"：Sliding (0.95): 表面间滑动摩擦，很高，类似橡胶，Torsional (0.3): 绕法线旋转的摩擦，为零；Rolling (0.1)：滚动摩擦，为零 -->
            <geom mesh="can_mesh" type="mesh" solimp="0.998 0.998 0.001" solref="0.001 1" density="100" friction="0.95 0.3 0.1" material="can_mat" condim="4"/>
        </body>

        <body pos="-2.8 1.5 1">
            <freejoint/>
            <geom type="box" size=".025 .025 .025" rgba=".0 .8 .0 1" condim="3"/>
        </body>

        <body name="container_box" pos="2.5 1.4 0.8">
            <freejoint/>
            <!-- 底板：size="0.2 0.2 0.006" → 20x20×1.2 cm -->
            <geom name="container_bottom" type="box" size="0.2 0.2 0.006" pos="0 0 0" material="container_material" group="0" condim="4"/>
            <geom name="container_back_wall" type="box" size="0.195 0.005 0.09" pos="0 0.195 0.096" material="container_material" group="0" condim="4"/>
            <geom name="container_front_wall" type="box" size="0.195 0.005 0.09" pos="0 -0.195 0.096" material="container_material" group="0" condim="4"/>
            <geom name="container_left_wall" type="box" size="0.005 0.19 0.09" pos="-0.195 0 0.096" material="container_material" group="0" condim="4"/>
            <geom name="container_right_wall" type="box" size="0.005 0.19 0.09" pos="0.195 0 0.096" material="container_material" group="0" condim="4"/>
        </body>
    </worldbody>

    <keyframe>
        <key name="home" qpos="0 0 0 0 0.26179939 3.14159265 -2.26892803 0 0.95993109 1.57079633 0 0 0 0 0 0 0 0" ctrl="0 0 0 0 0.26179939 3.14159265 -2.26892803 0 0.95993109 1.57079633 0"/>
        <key name="retract" qpos="0 0 0 0 -0.34906585 3.14159265 -2.54818071 0 -0.87266463 1.57079633 0 0 0 0 0 0 0 0" ctrl="0 0 0 0 -0.34906585 3.14159265 -2.54818071 0 -0.87266463 1.57079633 0"/>
    </keyframe>
</mujoco>