# ========== Hugging Face ==========
HF_ENDPOINT="https://hf-mirror.com"
HF_HOME=~/.cache/huggingface
# HF_TOKEN=~/.cache/huggingface/token

# CACHE_DIR=~/.cache/huggingface/hub # 与 HF_HUB_CACHE 一致
HF_HUB_CACHE=~/.cache/huggingface/hub

# ========== LeRobot ==========
HF_LEROBOT_HOME=~/.cache/huggingface/lerobot
HF_LEROBOT_HUB_CACHE=~/.cache/huggingface/lerobot/hub
HF_LEROBOT_CALIBRATION=~/.cache/huggingface/lerobot/calibration

# ========== proxy ==========
# HTTP_PROXY="http://127.0.0.1:7890"
# HTTPS_PROXY="http://127.0.0.1:7890"